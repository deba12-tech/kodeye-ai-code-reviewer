# Kodeye Backend Environment Configuration
# This is the template file. Copy to .env and fill in actual values.

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=development
DEBUG=true
APP_NAME="Kodeye Security Audit Engine"
VERSION=1.0.0

# ============================================================================
# SERVER
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============================================================================
# DATABASE
# ============================================================================
# For development: SQLite (default)
# For production: PostgreSQL
DATABASE_URL=sqlite:///./kodeye.db
# DATABASE_URL=postgresql://user:password@localhost:5432/kodeye

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Token encryption key for OAuth tokens (Fernet key format)
TOKEN_ENCRYPTION_KEY=

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Backend: console (development), smtp, or sendgrid
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@kodeye.com

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@kodeye.com

# ============================================================================
# OAUTH PROVIDERS
# ============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ============================================================================
# ERROR TRACKING (SENTRY)
# ============================================================================
SENTRY_DSN=
# SENTRY_DSN=https://key@sentry.io/project-id

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
